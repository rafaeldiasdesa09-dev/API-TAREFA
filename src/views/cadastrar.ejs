<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Cadastro de Tarefas</title>

  <link rel="stylesheet" href="/css/cadastrar.css">
</head>

<body>

  <div class="container">

    <h1> Cadastro de Tarefas</h1>

    <!-- Formulário de cadastro -->
    <form class="cadastro" method="POST" action="/tarefas">

      <input
        type="text"
        name="titulo"
        placeholder="Digite uma tarefa..."
        required
      >

      <button type="submit" class="btn-add">
        ➕ Adicionar
      </button>

    </form>

    <!-- Lista de tarefas -->
    <table>

      <thead>
        <tr>
          <th>Tarefa</th>
          <th>Ações</th>
        </tr>
      </thead>

      <tbody>

        <% if (tarefas.length === 0) { %>

          <tr>
            <td colspan="2">
              Nenhuma tarefa cadastrada.
            </td>
          </tr>

        <% } %>

        <% tarefas.forEach((t) => { %>

          <tr>

            <!-- Título -->
            <td>

              <% if (t.concluida) { %>

                <span class="concluida">
                  <%= t.titulo %>
                </span>

              <% } else { %>

                <strong>
                  <%= t.titulo %>
                </strong>

              <% } %>

            </td>

            <!-- Botão concluir/reabrir -->
            <td>

              <form
                method="POST"
                action="/tarefas/<%= t.id %>/concluir"
                class="inline"
              >

                <% if (t.concluida) { %>

                  <button type="submit" class="btn-reabrir">
                    🔄 Reabrir
                  </button>

                <% } else { %>

                  <button type="submit" class="btn-concluir">
                    ✅ Concluir
                  </button>

                <% } %>

              </form>

            </td>

          </tr>

        <% }) %>

      </tbody>

    </table>

  </div>

</body>
</html>