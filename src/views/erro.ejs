<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Erro</title>

  <style>
    body {
      background: #121212;
      color: white;
      font-family: Arial;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
    }

    .box {
      background: #1e1e1e;
      padding: 30px;
      border-radius: 10px;
      width: 400px;
      text-align: center;
    }

    h1 {
      color: #ff4d4d;
    }

    p {
      color: #ccc;
    }
  </style>
</head>
<body>

  <div class="box">
    <h1>Erro</h1>
    <p><%= mensagem %></p>
  </div>

</body>
</html>