<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Detalhes da Tarefa</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #121212;
      color: white;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
    }

    .card {
      background: #1e1e1e;
      padding: 30px;
      border-radius: 10px;
      width: 500px;
      box-shadow: 0 0 15px rgba(0,0,0,0.4);
    }

    h1 {
      margin-bottom: 20px;
      color: #00bfff;
    }

    p {
      margin: 10px 0;
    }

    strong {
      color: #00bfff;
    }

    .status {
      padding: 5px 10px;
      border-radius: 5px;
      display: inline-block;
      margin-top: 10px;
    }

    .feito {
      background: #28a745;
    }

    .pendente {
      background: #dc3545;
    }
  </style>
</head>
<body>

  <div class="card">
    <h1>Detalhes da Tarefa</h1>

    <p>
      <strong>ID:</strong>
      <%= tarefa.id %>
    </p>

    <p>
      <strong>Título:</strong>
      <%= tarefa.titulo %>
    </p>

    <p>
      <strong>Descrição:</strong>
      <%= tarefa.descricao %>
    </p>

    <p>
      <strong>Status:</strong>

      <% if (tarefa.concluida) { %>
        <span class="status feito">Concluída</span>
      <% } else { %>
        <span class="status pendente">Pendente</span>
      <% } %>
      res.render("detalhe", { tarefa: algumaTarefa })
    </p>
  </div>

</body>
</html>